VITE_API_URL=http://127.0.0.1:5000
# For LAN sharing set your host IP:port (no trailing /api)
# Example: VITE_API_URL=http://192.168.1.15:5000

# Dev server commands:
# Backend: cd Backend && flask --app wsgi.py run --host=0.0.0.0 --port=5000
# Frontend: cd Frontend && npm run dev
# Access via the Vite network URL (e.g. http://192.168.56.1:3000)

